# Reconator config — copy to .env for docker-compose

# Telegram notifications (optional — leave blank to disable)
TELEGRAM_API_KEY=
TELEGRAM_CHAT_ID=

# Database
POSTGRES_USER=reconator
POSTGRES_PASSWORD=reconator
POSTGRES_DB=reconator

# Worker
WORKER_POLL_INTERVAL_SECONDS=30
MODULE_TIMEOUT_SECONDS=1800
