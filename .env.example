# Reconator config — copy to .env for docker-compose

# Auth — when set, mutations require X-API-Key header. Leave blank for open dev.
ADMIN_API_KEY=

# Telegram notifications (optional — leave blank to disable)
TELEGRAM_API_KEY=
TELEGRAM_CHAT_ID=

# Webhook notifications (optional)
# WEBHOOK_KIND: generic | slack | discord
WEBHOOK_URL=
WEBHOOK_KIND=generic

# Observability
SENTRY_DSN=

# Rate limiting (slowapi expressions)
RATE_LIMIT_WRITES=20/minute
RATE_LIMIT_BULK=5/minute

# Database
POSTGRES_USER=reconator
POSTGRES_PASSWORD=reconator
POSTGRES_DB=reconator

# Worker
WORKER_POLL_INTERVAL_SECONDS=30
MODULE_TIMEOUT_SECONDS=1800
